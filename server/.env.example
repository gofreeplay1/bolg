# ===========================================
# Blog Admin 数据库配置
# ===========================================
# 
# 数据库模式: 双模式支持
#   1. MySQL 模式 - 配置以下 MySQL 连接信息
#   2. SQLite 模式 - 留空 MySQL 配置，自动使用本地 SQLite
#
# 切换方式:
#   - 使用 MySQL: 填写 DB_HOST, DB_USER, DB_PASSWORD
#   - 使用 SQLite: 将以下 MySQL 字段留空或注释掉
# ===========================================

# --- MySQL 配置 (留空则自动使用 SQLite) ---
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_password
# DB_NAME=blog_admin

# --- JWT 密钥（请务必修改为随机字符串）---
JWT_SECRET=change_me_to_a_random_secret_string

# --- 服务器端口 ---
PORT=3001

# --- 默认管理员账号（首次启动时自动创建）---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
